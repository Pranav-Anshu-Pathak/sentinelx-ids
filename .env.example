# ╔══════════════════════════════════════════════════════════╗
# ║           SENTINELX IDS — ENVIRONMENT CONFIG            ║
# ╚══════════════════════════════════════════════════════════╝

# ── Application ──
APP_NAME=SentinelX IDS
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=false

# ── Backend Server ──
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
WS_PORT=8001
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── Database ──
DATABASE_URL=sqlite+aiosqlite:///./sentinelx.db
# DATABASE_URL=postgresql+asyncpg://sentinelx:password@localhost:5432/sentinelx

# ── Authentication ──
SECRET_KEY=sentinelx-demo-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── Demo Mode ──
DEMO_MODE=true
DEMO_USERNAME=admin
DEMO_PASSWORD=sentinelx

# ── Elasticsearch (Optional) ──
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_ENABLED=false

# ── Redis (Optional) ──
REDIS_URL=redis://localhost:6379/0
REDIS_ENABLED=false

# ── Threat Intelligence API Keys ──
ABUSEIPDB_API_KEY=
ALIENVAULT_OTX_KEY=
VIRUSTOTAL_API_KEY=

# ── AI / LLM Integration (Optional) ──
# local = offline copilot (default). Set openai/anthropic/gemini + API key for cloud LLM.
LLM_PROVIDER=local
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# ── Alerting ──
SLACK_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL_TO=

# ── Log Collection ──
LOG_WATCH_PATHS=/var/log/auth.log,/var/log/syslog
LOG_RETENTION_DAYS=30
MAX_EVENTS_PER_SECOND=1000
